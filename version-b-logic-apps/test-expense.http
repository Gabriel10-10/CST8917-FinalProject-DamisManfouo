# test-expense.http — Version B: Logic Apps + Service Bus
# Use with the VS Code REST Client extension.
#
# HOW TESTING WORKS FOR VERSION B:
#   Each scenario sends a JSON message to the Service Bus queue "expense-requests".
#   The Logic App triggers automatically, runs the full workflow, and produces a result.
#   After sending each message, go to:
#     Azure Portal → FinalLogicApp → Run history → open the run → screenshot each branch.
#
# HOW TO GET YOUR BEARER TOKEN:
#   Run this in your terminal (requires az login):
#   az account get-access-token --resource https://servicebus.azure.net --query accessToken -o tsv
#   Copy the output and paste it as @bearerToken below.
#   Token expires in ~1 hour — re-run the command to refresh it.
#
# HOW TO GET YOUR NAMESPACE:
#   Azure Portal → Service Bus namespace → Overview → copy the "Host name"
#   It looks like: finalservicebus.servicebus.windows.net

@namespace = finalservicebus.servicebus.windows.net
@queue = expense-requests
@bearerToken = token

###############################################################################
# Scenario 1: Valid expense UNDER $100 → auto-approved (no manager needed)
###############################################################################

POST https://{{namespace}}/{{queue}}/messages
Authorization: Bearer {{bearerToken}}
Content-Type: application/json
BrokerProperties: {"Label": "expense-request"}

{
  "employee_name": "Alice Martin",
  "employee_email": "employee_email",
  "amount": 45.00,
  "category": "meals",
  "description": "Team lunch",
  "manager_email": "manager_email"
}

# Expected: Logic App runs → validation passes → amount < 100 → approved
# Screenshot: Logic App run history showing auto-approve branch + email received.

###############################################################################
# Scenario 2: Valid expense >= $100, manager APPROVES
###############################################################################

POST https://{{namespace}}/{{queue}}/messages
Authorization: Bearer {{bearerToken}}
Content-Type: application/json
BrokerProperties: {"Label": "expense-request"}

{
  "employee_name": "Bob Chen",
  "employee_email": "employee_email",
  "amount": 450.00,
  "category": "travel",
  "description": "Conference flight",
  "manager_email": "manager_email"
}

# Expected: Logic App pauses at HTTP Webhook → manager calls callback URL → approved
# Screenshot: Logic App run showing approved branch + email received.

###############################################################################
# Scenario 3: Valid expense >= $100, manager REJECTS
###############################################################################

POST https://{{namespace}}/{{queue}}/messages
Authorization: Bearer {{bearerToken}}
Content-Type: application/json
BrokerProperties: {"Label": "expense-request"}

{
  "employee_name": "Carol Lee",
  "employee_email": "employee_email",
  "amount": 1200.00,
  "category": "equipment",
  "description": "Ergonomic monitor",
  "manager_email": "manager_email"
}

# Expected: Logic App pauses at HTTP Webhook → manager rejects → rejected
# Screenshot: Logic App run showing rejected branch + email received.

###############################################################################
# Scenario 4: Valid expense >= $100, NO manager response → escalated
#
# HOW TO TEST:
#   1. Send this message.
#   2. Do NOT call the manager callback URL.
#   3. Wait for the HTTP Webhook timeout (PT2M = 2 minutes for testing).
#   4. Logic App follows timeout branch → escalated.
#   Screenshot: Logic App run showing timeout/escalated branch.
###############################################################################

POST https://{{namespace}}/{{queue}}/messages
Authorization: Bearer {{bearerToken}}
Content-Type: application/json
BrokerProperties: {"Label": "expense-request"}

{
  "employee_name": "David Kim",
  "employee_email": "employee_email",
  "amount": 800.00,
  "category": "software",
  "description": "Annual IDE license",
  "manager_email": "manager_email"
}

###############################################################################
# Scenario 5: Missing required field → validation error → rejected
###############################################################################

POST https://{{namespace}}/{{queue}}/messages
Authorization: Bearer {{bearerToken}}
Content-Type: application/json
BrokerProperties: {"Label": "expense-request"}

{
  "employee_name": "Eve Torres",
  "employee_email": "employee_email",
  "amount": 200.00,
  "category": "supplies",
  "manager_email": "manager_email"
}

# Missing: employee_email
# Expected: validation function returns valid=false → Logic App False branch → rejected
# Screenshot: Logic App run showing False branch of validation condition.

###############################################################################
# Scenario 6: Invalid category → validation error → rejected
###############################################################################

POST https://{{namespace}}/{{queue}}/messages
Authorization: Bearer {{bearerToken}}
Content-Type: application/json
BrokerProperties: {"Label": "expense-request"}

{
  "employee_name": "Frank Nguyen",
  "employee_email": "employee_email",
  "amount": 75.00,
  "category": "lunch",
  "description": "Team lunch",
  "manager_email": "manager_email"
}

# "lunch" is not in VALID_CATEGORIES.
# Expected: validation function returns valid=false → Logic App False branch → rejected
# Screenshot: Logic App run showing False branch of validation condition.
